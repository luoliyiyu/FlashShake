<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashShake.MainPage">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Padding="20">

        <Label Grid.Row="0" Text="FlashShake" FontSize="24" TextColor="#0050EF" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10,0,20"/>

        <Label Grid.Row="1" Text="Current status:" FontSize="14" Margin="0,0,0,5" TextColor="Gray"/>

        <Border Grid.Row="2" BackgroundColor="#F0F8FF" CornerRadius="10" Padding="15" HasShadow="False" BorderColor="#B0C4DE">
            <VerticalStackLayout Spacing="5">
                <Label x:Name="StatusLabel" Text="Status: Close" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
                <Label x:Name="ModeLabel" Text="Model: Normal" FontSize="14" TextColor="Black"/>
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="3" VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">

            <Button x:Name="PowerButton" Text="OFF" FontSize="20" FontAttributes="Bold" WidthRequest="130" HeightRequest="130" CornerRadius="65" BackgroundColor="#E0E0E0" TextColor="Black" Clicked="PowerButton_Clicked"/>

            <Button Text="SOS MODE" Clicked="SOSMode_Clicked" TextColor="Red" BackgroundColor="Transparent" BorderColor="Red" BorderWidth="1.5" CornerRadius="15" WidthRequest="110" HeightRequest="35"/>

        </VerticalStackLayout>

        <Grid Grid.Row="4" ColumnDefinitions="*, *, *, *" Margin="0,20,0,0">

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="NavMain_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="🏠" FontSize="24" HorizontalOptions="Center"/>
                <Label Text="Main" FontSize="12" HorizontalOptions="Center" TextColor="#0050EF" FontAttributes="Bold"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="NavShake_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="📳" FontSize="24" HorizontalOptions="Center"/>
                <Label Text="Shake" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="NavSupport_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border Stroke="Gray" StrokeThickness="1.5" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" BackgroundColor="Transparent">
                    <Label Text="LED" FontSize="9" TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                </Border>
                <Label Text="Support" FontSize="12" HorizontalOptions="Center" TextColor="Gray" Margin="0,3,0,0"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="NavSettings_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="⚙️" FontSize="24" HorizontalOptions="Center"/>
                <Label Text="Settings" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
            </VerticalStackLayout>

        </Grid>
    </Grid>

</ContentPage>
