<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashShake.SettingPage">

	<Grid RowDefinitions="Auto, *, Auto" Padding="20">

		<Label Grid.Row="0" Text="FlashShake" FontSize="24" TextColor="#0050EF" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10,0,20"/>

		<ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
			<VerticalStackLayout Spacing="20" Margin="0,0,0,20">

				<VerticalStackLayout Spacing="10">
					<Label Text="Basic settings" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
					<Frame BackgroundColor="#99000000" CornerRadius="10" Padding="15" HasShadow="False" BorderColor="Transparent">
						<VerticalStackLayout Spacing="15">

							<Grid ColumnDefinitions="*, Auto">
								<Label Grid.Column="0" Text="Switch on flashlight" TextColor="White" VerticalOptions="Center" FontSize="14"/>
								<Border Grid.Column="1" WidthRequest="50" HeightRequest="26" Stroke="#A0A0A0" StrokeThickness="1.5" BackgroundColor="Transparent" StrokeShape="RoundRectangle 13" Padding="2">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="CustomSwitch_Tapped" />
									</Border.GestureRecognizers>
									<Ellipse WidthRequest="22" HeightRequest="22" Fill="#A0A0A0" HorizontalOptions="Start" TranslationX="0"/>
								</Border>
							</Grid>

							<Grid ColumnDefinitions="*, Auto">
								<Label Grid.Column="0" Text="Switch mode" TextColor="White" VerticalOptions="Center" FontSize="14"/>
								<Border Grid.Column="1" WidthRequest="50" HeightRequest="26" Stroke="#A0A0A0" StrokeThickness="1.5" BackgroundColor="Transparent" StrokeShape="RoundRectangle 13" Padding="2">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="CustomSwitch_Tapped" />
									</Border.GestureRecognizers>
									<Ellipse WidthRequest="22" HeightRequest="22" Fill="#A0A0A0" HorizontalOptions="Start" TranslationX="0"/>
								</Border>
							</Grid>

							<Grid ColumnDefinitions="*, Auto">
								<Label Grid.Column="0" Text="Activate SOS" TextColor="White" VerticalOptions="Center" FontSize="14"/>
								<Border Grid.Column="1" WidthRequest="50" HeightRequest="26" Stroke="#A0A0A0" StrokeThickness="1.5" BackgroundColor="Transparent" StrokeShape="RoundRectangle 13" Padding="2">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="CustomSwitch_Tapped" />
									</Border.GestureRecognizers>
									<Ellipse WidthRequest="22" HeightRequest="22" Fill="#A0A0A0" HorizontalOptions="Start" TranslationX="0"/>
								</Border>
							</Grid>

						</VerticalStackLayout>
					</Frame>
				</VerticalStackLayout>

				<VerticalStackLayout Spacing="10">
					<Label Text="Advanced settings" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
					<Frame BackgroundColor="#99000000" CornerRadius="10" Padding="15" HasShadow="False" BorderColor="Transparent">
						<VerticalStackLayout Spacing="15">

							<Grid ColumnDefinitions="*, Auto">
								<Label Grid.Column="0" Text="Power saving mode" TextColor="White" VerticalOptions="Center" FontSize="14"/>
								<Border Grid.Column="1" WidthRequest="50" HeightRequest="26" Stroke="#A0A0A0" StrokeThickness="1.5" BackgroundColor="Transparent" StrokeShape="RoundRectangle 13" Padding="2">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="CustomSwitch_Tapped" />
									</Border.GestureRecognizers>
									<Ellipse WidthRequest="22" HeightRequest="22" Fill="#A0A0A0" HorizontalOptions="Start" TranslationX="0"/>
								</Border>
							</Grid>

							<Grid ColumnDefinitions="*, Auto">
								<Label Grid.Column="0" Text="Check for updates on startup" TextColor="White" VerticalOptions="Center" FontSize="14"/>
								<Border Grid.Column="1" WidthRequest="50" HeightRequest="26" Stroke="#A0A0A0" StrokeThickness="1.5" BackgroundColor="Transparent" StrokeShape="RoundRectangle 13" Padding="2">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="CustomSwitch_Tapped" />
									</Border.GestureRecognizers>
									<Ellipse WidthRequest="22" HeightRequest="22" Fill="#A0A0A0" HorizontalOptions="Start" TranslationX="0"/>
								</Border>
							</Grid>

							<Grid ColumnDefinitions="*, Auto">
								<Label Grid.Column="0" Text="Automatically save settings" TextColor="White" VerticalOptions="Center" FontSize="14"/>
								<Border Grid.Column="1" WidthRequest="50" HeightRequest="26" Stroke="#0050EF" StrokeThickness="1.5" BackgroundColor="#0050EF" StrokeShape="RoundRectangle 13" Padding="2">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="CustomSwitch_Tapped" />
									</Border.GestureRecognizers>
									<Ellipse WidthRequest="22" HeightRequest="22" Fill="White" HorizontalOptions="Start" TranslationX="24"/>
								</Border>
							</Grid>

						</VerticalStackLayout>
					</Frame>
				</VerticalStackLayout>

				<VerticalStackLayout Spacing="10">
					<Label Text="About" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
					<Frame BackgroundColor="#99000000" CornerRadius="10" Padding="15" HasShadow="False" BorderColor="Transparent">
						<VerticalStackLayout Spacing="10">
							<Label Text="Version: 1.0.2" TextColor="White" FontSize="14"/>
							<Label Text="Developer: Zheng Chenjun" TextColor="White" FontSize="14"/>
						</VerticalStackLayout>
					</Frame>
				</VerticalStackLayout>

				<Grid ColumnDefinitions="*, *" ColumnSpacing="20" Margin="0,10,0,0">
					<Button Grid.Column="0" Text="Restore default" Clicked="Restore_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8"/>
					<Button Grid.Column="1" Text="Saving settings" Clicked="Save_Clicked" BackgroundColor="#0050EF" TextColor="White" CornerRadius="8"/>
				</Grid>

			</VerticalStackLayout>
		</ScrollView>

		<Grid Grid.Row="2" ColumnDefinitions="*, *, *, *" Margin="0,10,0,0">
			<Border Grid.Column="0" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="NavMain_Tapped" />
				</Border.GestureRecognizers>
				<VerticalStackLayout HorizontalOptions="Center">
					<Label Text="🏠" FontSize="24" HorizontalOptions="Center"/>
					<Label Text="Main" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
				</VerticalStackLayout>
			</Border>
			<Border Grid.Column="1" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="NavShake_Tapped" />
				</Border.GestureRecognizers>
				<VerticalStackLayout HorizontalOptions="Center">
					<Label Text="📳" FontSize="24" HorizontalOptions="Center"/>
					<Label Text="Shake" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
				</VerticalStackLayout>
			</Border>
			<Border Grid.Column="2" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="NavSupport_Tapped" />
				</Border.GestureRecognizers>
				<VerticalStackLayout HorizontalOptions="Center">
					<Border Stroke="Gray" StrokeThickness="1.5" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" BackgroundColor="Transparent">
						<Label Text="LED" FontSize="9" TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
					</Border>
					<Label Text="Support" FontSize="12" HorizontalOptions="Center" TextColor="Gray" Margin="0,3,0,0"/>
				</VerticalStackLayout>
			</Border>
			<Border Grid.Column="3" Stroke="Transparent" BackgroundColor="Black" Padding="15,5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
				<VerticalStackLayout HorizontalOptions="Center">
					<Label Text="⚙️" FontSize="24" HorizontalOptions="Center"/>
					<Label Text="Setting" FontSize="12" HorizontalOptions="Center" TextColor="White" FontAttributes="Bold"/>
				</VerticalStackLayout>
			</Border>
		</Grid>
	</Grid>

</ContentPage>
