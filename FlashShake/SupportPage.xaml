<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashShake.SupportPage">

	<Grid RowDefinitions="Auto, *, Auto" Padding="20">

		<Label Grid.Row="0" Text="FlashShake" FontSize="24" TextColor="#0050EF" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10,0,20"/>

		<ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
			<VerticalStackLayout Spacing="15" Margin="0,0,0,20">

				<Frame x:Name="PreviewFrame" BackgroundColor="Black" CornerRadius="15" HeightRequest="120" HasShadow="True" Padding="0">
					<Grid x:Name="ViewportGrid" HorizontalOptions="Fill" VerticalOptions="Fill" Margin="10,0">
						<Label x:Name="PreviewLabel"
                               Text="Hello!"
                               TextColor="Blue"
                               FontSize="36"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               LineBreakMode="NoWrap"/>
					</Grid>
				</Frame>

				<Label Text="Mobile phone display effectxt" FontSize="12" TextColor="Gray" HorizontalOptions="Center" Margin="0,-10,0,10"/>

				<Label Text="Color scheme:" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
				<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *, *, *" RowSpacing="15" ColumnSpacing="15">
					<Border x:Name="Color1" Grid.Row="0" Grid.Column="0" BackgroundColor="Black" Stroke="White" StrokeThickness="3" HeightRequest="50" CornerRadius="8">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="ColorScheme_Tapped" CommandParameter="1"/>
						</Border.GestureRecognizers>
						<Label Text="A" TextColor="Blue" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
					</Border>
					<Border x:Name="Color2" Grid.Row="0" Grid.Column="1" BackgroundColor="Orange" Stroke="Transparent" StrokeThickness="3" HeightRequest="50" CornerRadius="8">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="ColorScheme_Tapped" CommandParameter="2"/>
						</Border.GestureRecognizers>
						<Label Text="A" TextColor="Black" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
					</Border>
					<Border x:Name="Color3" Grid.Row="0" Grid.Column="2" BackgroundColor="Blue" Stroke="Transparent" StrokeThickness="3" HeightRequest="50" CornerRadius="8">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="ColorScheme_Tapped" CommandParameter="3"/>
						</Border.GestureRecognizers>
						<Label Text="A" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
					</Border>
					<Border x:Name="Color4" Grid.Row="0" Grid.Column="3" BackgroundColor="Red" Stroke="Transparent" StrokeThickness="3" HeightRequest="50" CornerRadius="8">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="ColorScheme_Tapped" CommandParameter="4"/>
						</Border.GestureRecognizers>
						<Label Text="A" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
					</Border>
					<Border x:Name="Color5" Grid.Row="1" Grid.Column="0" BackgroundColor="LightBlue" Stroke="Transparent" StrokeThickness="3" HeightRequest="50" CornerRadius="8">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="ColorScheme_Tapped" CommandParameter="5"/>
						</Border.GestureRecognizers>
						<Label Text="A" TextColor="Green" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
					</Border>
					<Border x:Name="Color6" Grid.Row="1" Grid.Column="1" BackgroundColor="Green" Stroke="Transparent" StrokeThickness="3" HeightRequest="50" CornerRadius="8">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="ColorScheme_Tapped" CommandParameter="6"/>
						</Border.GestureRecognizers>
						<Label Text="A" TextColor="Black" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
					</Border>
					<Border x:Name="Color7" Grid.Row="1" Grid.Column="2" BackgroundColor="Black" Stroke="Transparent" StrokeThickness="3" HeightRequest="50" CornerRadius="8">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="ColorScheme_Tapped" CommandParameter="7"/>
						</Border.GestureRecognizers>
						<Label Text="A" TextColor="Red" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
					</Border>
					<Border x:Name="Color8" Grid.Row="1" Grid.Column="3" BackgroundColor="LightPink" Stroke="Transparent" StrokeThickness="3" HeightRequest="50" CornerRadius="8">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="ColorScheme_Tapped" CommandParameter="8"/>
						</Border.GestureRecognizers>
						<Label Text="A" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
					</Border>
				</Grid>

				<BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,10"/>

				<Grid ColumnDefinitions="100, *">
					<Label Grid.Column="0" Text="Font size" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="Black"/>
					<HorizontalStackLayout Grid.Column="1" Spacing="10" HorizontalOptions="End">
						<Button x:Name="BtnFontLow" Text="Low" Clicked="FontSize_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
						<Button x:Name="BtnFontMedium" Text="Medium" Clicked="FontSize_Clicked" BackgroundColor="Black" TextColor="White" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
						<Button x:Name="BtnFontHigh" Text="High" Clicked="FontSize_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
					</HorizontalStackLayout>
				</Grid>

				<Grid ColumnDefinitions="100, *">
					<Label Grid.Column="0" Text="Scroll" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="Black"/>
					<HorizontalStackLayout Grid.Column="1" Spacing="10" HorizontalOptions="End">
						<Button x:Name="BtnScrollLeft" Text="Left" Clicked="Scroll_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
						<Button x:Name="BtnScrollCenter" Text="Center" Clicked="Scroll_Clicked" BackgroundColor="Black" TextColor="White" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
						<Button x:Name="BtnScrollRight" Text="Right" Clicked="Scroll_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
					</HorizontalStackLayout>
				</Grid>

				<Grid ColumnDefinitions="100, *">
					<Label Grid.Column="0" Text="Speed" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="Black"/>
					<HorizontalStackLayout Grid.Column="1" Spacing="10" HorizontalOptions="End">
						<Button x:Name="BtnSpeedSlow" Text="Slow" Clicked="Speed_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
						<Button x:Name="BtnSpeedNormal" Text="Normal" Clicked="Speed_Clicked" BackgroundColor="Black" TextColor="White" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
						<Button x:Name="BtnSpeedQuick" Text="Quick" Clicked="Speed_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8" HeightRequest="35" Padding="10,0"/>
					</HorizontalStackLayout>
				</Grid>

				<BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,10"/>

				<Grid ColumnDefinitions="*, 80" ColumnSpacing="10">
					<Entry x:Name="TextInput" Grid.Column="0" Placeholder="Enter text here..." TextColor="Black" BackgroundColor="#F5F5F5" />
					<Button Grid.Column="1" Text="Sumbit" Clicked="Submit_Clicked" BackgroundColor="#0050EF" TextColor="White" CornerRadius="8"/>
				</Grid>

			</VerticalStackLayout>
		</ScrollView>

		<Grid Grid.Row="2" ColumnDefinitions="*, *, *, *" Margin="0,10,0,0">
			<Border Grid.Column="0" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="NavMain_Tapped" />
				</Border.GestureRecognizers>
				<VerticalStackLayout HorizontalOptions="Center">
					<Label Text="🏠" FontSize="24" HorizontalOptions="Center"/>
					<Label Text="Main" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
				</VerticalStackLayout>
			</Border>
			<Border Grid.Column="1" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="NavShake_Tapped" />
				</Border.GestureRecognizers>
				<VerticalStackLayout HorizontalOptions="Center">
					<Label Text="📳" FontSize="24" HorizontalOptions="Center"/>
					<Label Text="Shake" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
				</VerticalStackLayout>
			</Border>
			<Border Grid.Column="2" Stroke="Transparent" BackgroundColor="Black" Padding="15,5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
				<VerticalStackLayout HorizontalOptions="Center">
					<Border Stroke="White" StrokeThickness="1.5" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" BackgroundColor="Transparent">
						<Label Text="LED" FontSize="9" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
					</Border>
					<Label Text="Support" FontSize="12" HorizontalOptions="Center" TextColor="White" FontAttributes="Bold" Margin="0,3,0,0"/>
				</VerticalStackLayout>
			</Border>
			<Border Grid.Column="3" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="NavSetting_Tapped" />
				</Border.GestureRecognizers>
				<VerticalStackLayout HorizontalOptions="Center">
					<Label Text="⚙️" FontSize="24" HorizontalOptions="Center"/>
					<Label Text="Setting" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
				</VerticalStackLayout>
			</Border>
		</Grid>
	</Grid>

</ContentPage>
