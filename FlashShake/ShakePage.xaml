<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashShake.ShakePage">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        
        <Label Grid.Row="0" Text="FlashShake" FontSize="24" TextColor="#0050EF" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10,0,20"/>

        <VerticalStackLayout Grid.Row="1" Spacing="20" VerticalOptions="Start" Margin="0,20,0,0">
            <Label Text="Shake setting:" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
            
            <Frame BackgroundColor="#F0F8FF" CornerRadius="10" Padding="20" HasShadow="False" BorderColor="#B0C4DE">
                <VerticalStackLayout Spacing="15">
                    
                    <Label Text="Shake sensitivity:" FontSize="16" TextColor="Black" FontAttributes="Bold"/>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Button x:Name="BtnLow" Text="Low" Clicked="Sensitivity_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" WidthRequest="85" CornerRadius="8"/>
                        <Button x:Name="BtnMedium" Text="Medium" Clicked="Sensitivity_Clicked" BackgroundColor="Black" TextColor="White" WidthRequest="85" CornerRadius="8"/>
                        <Button x:Name="BtnHigh" Text="High" Clicked="Sensitivity_Clicked" BackgroundColor="#E0E0E0" TextColor="Black" WidthRequest="85" CornerRadius="8"/>
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#B0C4DE" Margin="0,10"/>

                    <Label Text="Shake times for Normal mode:" FontSize="14" TextColor="Black" FontAttributes="Bold"/>
                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Button Text="-" Clicked="NormalMinus_Clicked" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="#E0E0E0" TextColor="Black" FontAttributes="Bold" FontSize="18"/>
                        <Label x:Name="NormalTimesLabel" Text="2" FontSize="20" TextColor="Black" VerticalOptions="Center" FontAttributes="Bold"/>
                        <Button Text="+" Clicked="NormalPlus_Clicked" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="#E0E0E0" TextColor="Black" FontAttributes="Bold" FontSize="18"/>
                    </HorizontalStackLayout>

                    <Label Text="Shake times for SOS mode:" FontSize="14" TextColor="Black" FontAttributes="Bold" Margin="0,5,0,0"/>
                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Button Text="-" Clicked="SOSMinus_Clicked" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="#E0E0E0" TextColor="Black" FontAttributes="Bold" FontSize="18"/>
                        <Label x:Name="SOSTimesLabel" Text="3" FontSize="20" TextColor="Black" VerticalOptions="Center" FontAttributes="Bold"/>
                        <Button Text="+" Clicked="SOSPlus_Clicked" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="#E0E0E0" TextColor="Black" FontAttributes="Bold" FontSize="18"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <Grid Grid.Row="2" ColumnDefinitions="*, *, *, *" Margin="0,20,0,0">
            <Border Grid.Column="0" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="NavMain_Tapped" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="🏠" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Main" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1" Stroke="Transparent" BackgroundColor="Black" Padding="15,5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="📳" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Shake" FontSize="12" HorizontalOptions="Center" TextColor="White" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="2" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="NavSupport_Tapped" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center">
                    <Border Stroke="Gray" StrokeThickness="1.5" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" BackgroundColor="Transparent">
                        <Label Text="LED" FontSize="9" TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                    </Border>
                    <Label Text="Support" FontSize="12" HorizontalOptions="Center" TextColor="Gray" Margin="0,3,0,0"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="3" Stroke="Transparent" BackgroundColor="Transparent" Padding="5" StrokeShape="RoundRectangle 10" HorizontalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="NavSettings_Tapped" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="⚙️" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Setting" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
